# =============================================================
# Hermes + Football Auto 完整部署配置模板
# 使用方法：
#   cp .env.hermes.example .env
#   然后按需编辑本文件，填写必填项
# =============================================================

# ─── Football Auto 服务基础 ───────────────────────────────────

# 服务端口（默认 3000，访问 http://服务器IP:3000）
APP_PORT=3000

# SQLite 数据库路径（容器内路径，会挂载到 ./data/ 目录）
DATABASE_PATH=./data/app.sqlite

# 时区
TIMEZONE=Asia/Shanghai

# 公开报告访问地址（填你的服务器公网 IP 或域名）
# 示例：PUBLIC_REPORT_BASE_URL=http://1.2.3.4:3000/reports
PUBLIC_REPORT_BASE_URL=http://YOUR_SERVER_IP:3000/reports

# ─── Hermes Studio Web UI ────────────────────────────────────

# Hermes 镜像（一般不用修改）
WEBUI_IMAGE=ekkoye8888/hermes-web-ui

# Hermes Web UI 访问端口（默认 6060，访问 http://服务器IP:6060）
HERMES_PORT=6060

# Hermes 持久化数据目录（相对于 server/ 目录）
HERMES_DATA_DIR=./hermes_data

# ─── 采集配置 ─────────────────────────────────────────────────

# Titan007/球探数据源地址（通常不用修改）
TITAN_BASE_URL=https://live.titan007.com

# 采集并发数（降低此值可减少对数据源的压力）
COLLECT_CONCURRENCY=4

# 每日自动采集 Cron 表达式（默认每天 08:00 Asia/Shanghai 触发）；填 false 可关闭
DAILY_COLLECT_CRON=0 8 * * *

# 每日赛果同步 Cron 表达式（默认每天 23:00 Asia/Shanghai 触发）；填 false 可关闭
RESULT_SYNC_CRON=0 23 * * *

# 赛前自动刷新间隔（分钟）
PREMATCH_REFRESH_MINUTES=15

# 生产采集失败是否允许样例降级
# 当前生产采集器不做样例降级；上线运营请保持 0。
# 如需离线验证完整链路，请运行：npm run smoke:local
ALLOW_SAMPLE_FALLBACK=0

# ─── AI 配置 ──────────────────────────────────────────────────

# OpenAI-compatible 接口地址
# 重要：推荐只填到 /v1，程序会自动补 /chat/completions
# 正确示例：https://api.openai.com/v1
# 正确示例：https://your-custom-api.example.com/v1
# 兼容示例：https://api.openai.com/v1/chat/completions
AI_CUSTOM_ENDPOINT=https://api.openai.com/v1

# AI API Key
AI_API_KEY=sk-your-api-key-here

# AI 模型名称
AI_MODEL=gpt-4o-mini

# AI 请求超时时间（毫秒，默认 180 秒）
AI_TIMEOUT_MS=180000

# 每日最多生成完整长报告的比赛数量
# 超出此数量的比赛只生成短摘要，用于控制 AI 调用成本
AI_MAX_DAILY_MATCHES_FULL_REPORT=8

# ─── 飞书推送配置（推荐第一通道）─────────────────────────────

# 飞书自定义机器人 Webhook 地址
# 获取方式：进入飞书群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人
FEISHU_WEBHOOK=

# 飞书安全校验密钥（未开启安全校验的机器人留空）
FEISHU_SECRET=

# ─── 企业微信推送配置（第二通道）─────────────────────────────

# 企业微信群机器人 Webhook 地址
# 获取方式：进入企业微信群 → 添加群机器人 → 复制 Webhook 地址
WECOM_WEBHOOK=

# ─── QQ OneBot 推送配置（第三通道，需配套 NapCat 服务）───────

# OneBot HTTP 服务地址（NapCat 默认监听 3001 端口）
# 使用 Docker Compose 内网时，填 http://napcat:3001
ONEBOT_BASE_URL=http://napcat:3001

# OneBot 访问 Token（未开启鉴权可留空）
ONEBOT_ACCESS_TOKEN=

# 推送目标类型：group（群聊）或 private（私聊）
ONEBOT_TARGET_TYPE=group

# 推送目标 ID（群号或 QQ 号）
ONEBOT_TARGET_ID=

# ─── 推送路由 ─────────────────────────────────────────────────

# 自动推送渠道，多个渠道用英文逗号分隔，留空则不自动推送
# 可选值：feishu, wecom, onebot
# 示例（只推飞书）：AUTO_PUSH_CHANNELS=feishu
# 示例（多通道）：AUTO_PUSH_CHANNELS=feishu,wecom
AUTO_PUSH_CHANNELS=
