# =============================================================
# Football Auto 基础运行配置模板
# 使用方法：复制为 .env 后按需编辑
#   Windows PowerShell: Copy-Item .env.example .env
#   Linux/macOS:        cp .env.example .env
# =============================================================

# ─── 服务基础 ─────────────────────────────────────────────────

# 服务端运行端口
APP_PORT=3000

# SQLite 数据库路径
DATABASE_PATH=./data/app.sqlite

# 时区
TIMEZONE=Asia/Shanghai

# 公开报告访问地址
PUBLIC_REPORT_BASE_URL=http://localhost:3000/reports

# ─── 采集与定时任务 ───────────────────────────────────────────

# 数据源配置
TITAN_BASE_URL=https://live.titan007.com

# 采集并发数
COLLECT_CONCURRENCY=4

# 每日自动采集 Cron 表达式；填 false 可关闭
DAILY_COLLECT_CRON=0 8 * * *

# 每日赛果同步 Cron 表达式；填 false 可关闭
RESULT_SYNC_CRON=0 23 * * *

# 赛前自动刷新间隔（分钟）
PREMATCH_REFRESH_MINUTES=15

# 生产采集失败是否允许样例降级
# 当前生产采集器不做样例降级；上线运营请保持 0。
# 如需离线验证完整链路，请运行：npm run smoke:local
ALLOW_SAMPLE_FALLBACK=0

# ─── AI 配置 ─────────────────────────────────────────────────

# OpenAI-compatible 接口地址
# 推荐只填到 /v1，程序会自动补 /chat/completions；如果已填写完整 /chat/completions 也兼容。
AI_CUSTOM_ENDPOINT=https://api.openai.com/v1
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-4o-mini

# AI 请求超时时间（毫秒，默认 180 秒）
AI_TIMEOUT_MS=180000

# 每日最多生成完整长报告的比赛数量；超出部分走短摘要，控制成本
AI_MAX_DAILY_MATCHES_FULL_REPORT=8

# ─── 飞书推送配置 ─────────────────────────────────────────────
FEISHU_WEBHOOK=
FEISHU_SECRET=

# ─── 企业微信推送配置 ─────────────────────────────────────────
WECOM_WEBHOOK=

# ─── OneBot / QQ 推送配置 ─────────────────────────────────────
ONEBOT_BASE_URL=http://127.0.0.1:5700
ONEBOT_ACCESS_TOKEN=
ONEBOT_TARGET_TYPE=group
ONEBOT_TARGET_ID=

# ─── 推送路由 ─────────────────────────────────────────────────
# 自动推送渠道，多个渠道用英文逗号分隔，例如：feishu,wecom,onebot
AUTO_PUSH_CHANNELS=
